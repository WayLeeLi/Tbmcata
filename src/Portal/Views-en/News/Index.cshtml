@{
    ViewBag.Title = "News｜G-Wise Design";
}

@section Styles {
    <link href="/css/news.css" rel="stylesheet" />
    <style>
        /* Keep all links clickable, but hide most link default styles */
        .news-featured a:not(.more-link),
        .news-card a:not(.more-link) {
            text-decoration: none !important;
            color: inherit !important;
            background-color: transparent !important;
            cursor: pointer;
        }

            .news-featured a:not(.more-link):hover,
            .news-card a:not(.more-link):hover {
                text-decoration: none !important;
                color: inherit !important;
                background-color: transparent !important;
            }
        /* "Read More" link retains normal link style */
        .more-link {
            text-decoration: underline;
            cursor: pointer;
        }

            .more-link:hover {
                text-decoration: underline;
                opacity: 0.8;
            }
    </style>
}

@section Scripts {
    <script src="/js/news.js"></script>
}

<!-- HERO -->
<div class="page-hero">
    <div class="page-hero-bg"><img src="@ViewBag.HeroImage" /></div>
    <div class="page-hero-grad"></div>
    <div class="page-hero-content">
        <div class="eyebrow">
            <div class="eyebrow-line"></div>
            <span class="eyebrow-label">News &amp; Events</span>
        </div>
        <h1 class="page-title">News</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">Home</a>
    <span>›</span>
    <span style="color:#fff" id="bcText">@(ViewBag.CurrentCategoryName ?? "Latest News")</span>
</div>

<!-- TAB NAV -->
<div class="tab-nav">
    <a href="@Url.Action("Index", "News")" class="tab-btn @(ViewBag.CurrentCategoryId == 0 ? "active" : "")">All News</a>
    @if (ViewBag.CategoryList != null)
    {
        var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
        foreach (var cat in categories)
        {
            <a href="@Url.Action("Index", "News", new { categoryId = cat.Id })" class="tab-btn @(ViewBag.CurrentCategoryId == cat.Id ? "active" : "")">@cat.Name</a>
        }
    }
</div>

<!-- NEWS LIST -->
<div id="panelNews">
    @if (ViewBag.NewsList == null || ((IEnumerable<dynamic>)ViewBag.NewsList).Count() == 0)
    {
        <div style="text-align:center;padding:100px;color:var(--gray);">No news available</div>
    }
    else
    {
        var newsList = ViewBag.NewsList as List<Academy.Models.News> ?? new List<Academy.Models.News>();
        var featured = newsList.FirstOrDefault();

        <div class="news-wrap">
            @if (featured != null)
            {
                <div class="news-featured">
                    <div class="news-featured-img">
                        <a href="@Url.Action("Detail", "News", new { id = featured.ID })"><img src="@(featured.ImagePath ?? featured.ImagePath)" alt="@featured.Title" loading="lazy"></a>
                    </div>
                    <div class="news-featured-body">
                        <a href="@Url.Action("Detail", "News", new { id = featured.ID })" class="news-featured-date">
                            @featured.Title
                        </a>
                        <a href="@Url.Action("Detail", "News", new { id = featured.ID })">
                            <p class="news-featured-text">@featured.Note</p>
                        </a>
                        <a href="@Url.Action("Detail", "News", new { id = featured.ID })" class="more-link">Read More →</a>
                    </div>
                </div>
            }

            @if (newsList.Count > 1)
            {
                <div class="news-grid">
                    @for (int i = 1; i < newsList.Count; i++)
                    {
                        var item = newsList[i];
                        <div class="news-card">
                            <div class="news-card-img">
                                <a href="@Url.Action("Detail", "News", new { id = item.ID })"><img src="@(item.ImagePath ?? item.ImagePath)" alt="@item.Title" loading="lazy"></a>
                            </div>
                            <div class="news-card-body">
                                <a href="@Url.Action("Detail", "News", new { id = item.ID })" class="news-featured-date">
                                    @item.Title
                                </a>
                                <a href="@Url.Action("Detail", "News", new { id = item.ID })">
                                    <p class="news-card-text">@item.Note</p>
                                </a>
                                <a href="@Url.Action("Detail", "News", new { id = item.ID })" class="more-link">Read More →</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- HIRING TAB -->
<div id="panelHiring" style="display:none;">
    <div class="hiring-wrap">
        <div class="hiring-section">
            <h3>Corporate Spirit</h3>
            <p>Creating the highest brand value for customers based on different market needs is the corporate spirit of G-Wise Design. We are committed to designing with the mindset of creating maximum value for our customers. These core capabilities start with talent, combining collective wisdom to design products with beautiful appearance and excellent quality.</p>
        </div>

        <div class="hiring-section">
            <h3>Corporate Culture</h3>
            <p>G-Wise Design focuses on nurturing professional competence and character in our talents, with an open management style that emphasizes self-management and an innovative spirit.</p>
        </div>

        <div class="hiring-section">
            <h3>Challenges &amp; Opportunities</h3>
            <p>G-Wise Design continuously engages in planned product design, from product concept, product appearance design, mechanism design, to product prototyping. We sincerely welcome individuals with high adaptability who aspire to become well-rounded professionals to join our team.</p>
        </div>

        <div class="hiring-info-grid">
            <div class="hiring-info-card">
                <h4>Working Hours</h4>
                <p>Weekends off<br>08:30 — 17:30<br>1-hour lunch break</p>
            </div>
            <div class="hiring-info-card">
                <h4>Benefits</h4>
                <p>8% annual bonus distribution<br>Holiday gifts<br>Comprehensive labor and health insurance</p>
            </div>
            <div class="hiring-info-card">
                <h4>How to Apply</h4>
                <p>Download the application form, fill it out and email to:<br><a href="mailto:service@g-wise.com">service@g-wise.com</a></p>
            </div>
            <div class="hiring-info-card">
                <h4>Company Address</h4>
                <p>3F-2, No.9, Jingguo Rd., Taoyuan Dist., Taoyuan City 330, Taiwan<br>TEL：(03)358-2500</p>
            </div>
        </div>

        <a href="mailto:service@g-wise.com" class="hiring-cta">
            Submit Resume
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
    </div>
</div>

<!-- CTA BAR (already in Layout, can be omitted) -->