<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - 智匯創新 G-wise Design</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">

    <!-- jQuery & Plugins -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.imagesloaded/5.0.0/imagesloaded.pkgd.min.js"></script>

    <!-- Site Styles -->
    <link href="~/css/index.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        /* ========== 模态框样式 ========== */
        .modal {
            display: none;
            position: fixed;
            z-index: 9999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.7);
            overflow: auto;
        }

        .modal-content {
            background-color: #fff;
            margin: 10% auto;
            padding: 20px 20px 30px;
            border-radius: 16px;
            width: 90%;
            max-width: 360px;
            text-align: center;
            position: relative;
            animation: slideDown 0.3s ease-out;
        }

        .modal-header {
            margin-bottom: 15px;
        }

            .modal-header h2 {
                font-size: 1.5rem;
                margin: 0;
                color: #333;
            }

        .close {
            position: absolute;
            right: 18px;
            top: 12px;
            font-size: 28px;
            font-weight: bold;
            color: #aaa;
            cursor: pointer;
            transition: color 0.2s;
        }

            .close:hover {
                color: #000;
            }

        .modal-body p {
            margin: 12px 0;
            font-size: 14px;
            color: #555;
        }

        .modal-body a {
            color: #c00;
            text-decoration: none;
        }

            .modal-body a:hover {
                text-decoration: underline;
            }

        #qrcode-container {
            display: flex;
            justify-content: center;
            margin: 15px 0;
        }

            #qrcode-container img {
                max-width: 200px;
                height: auto;
            }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <!-- LANG BAR -->
    <div class="lang-bar" id="langBar">
        <a href="http://43.129.201.99:9001/" class="active" id="langZh">中文</a>
        <span class="lang-sep">|</span>
        <a href="http://43.129.201.99:9002/" id="langEn">English</a>
    </div>

    <!-- NAVBAR -->
    <nav id="navbar">
        <a href="@Url.Action("Index", "Home")" class="logo-area" style="display:flex;align-items:center;">
            <img src="~/images/web/templatemo_logo.png" alt="G-Wise Design Logo">
        </a>
        <ul class="nav-links">
            <li><a href="@Url.Action("Index", "Home")" id="navHome">首頁</a></li>
            <li><a href="@Url.Action("Index", "About")" id="navAbout">公司簡介</a></li>
            <li><a href="@Url.Action("Index", "Service")" id="navService">設計服務</a></li>
            <li><a href="@Url.Action("Index", "Product")" id="navProduct">作品集</a></li>
            <li><a href="@Url.Action("Index", "News")" id="navNews">新聞活動</a></li>
            <li><a href="@Url.Action("Index", "Contact")" id="navContact">聯絡我們</a></li>
            <li><a href="@Url.Action("Index", "Quote")" class="nav-cta btn-primary" id="navQuote">線上詢價</a></li>
        </ul>
        <div class="hamburger" id="ham" onclick="toggleMenu()">
            <span></span><span></span><span></span>
        </div>
    </nav>

    <!-- MOBILE MENU -->
    <div class="mobile-menu" id="mobileMenu">
        <a href="@Url.Action("Index", "Home")">首頁 Home</a>
        <a href="@Url.Action("Info", "About")">公司簡介 About</a>
        <a href="@Url.Action("Index", "Service")">設計服務 Service</a>
        <a href="@Url.Action("Index", "Product")">作品集 Portfolio</a>
        <a href="@Url.Action("Index", "News")">新聞活動 News</a>
        <a href="@Url.Action("Index", "Contact")">聯絡我們 Contact</a>
        <a href="@Url.Action("Index", "Quote")" style="color:var(--red)">線上詢價 Quotation</a>
    </div>

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- CTA BAR -->
    <div class="cta-bar">
        <div class="cta-title">有設計需求？<br>歡迎與我們聯繫合作</div>
        <a href="@Url.Action("Index", "Quote")" class="btn-white">立即詢價 →</a>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="footer-top">
            <div class="footer-brand">
                <div style="margin-bottom:16px;">
                    <img src="/images/web/templatemo_logo.png" alt="G-Wise Design Logo">
                </div>
                <p class="footer-tagline">
                    本著替客戶創造最高價值的心態做設計，<br>
                    是全方位的產品設計公司。
                </p>
            </div>

            <div class="footer-col">
                <h4>Services</h4>
                <ul class="footer-links">
                    <li><a href="@Url.Action("Services", "Home", new { category = "automotive" })">汽車零配件設計</a></li>
                    <li><a href="@Url.Action("Services", "Home", new { category = "motorcycle" })">摩托車設計服務</a></li>
                    <li><a href="@Url.Action("Services", "Home", new { category = "bicycle" })">自行車設計服務</a></li>
                    <li><a href="@Url.Action("Services", "Home", new { category = "marine" })">船舶外形設計</a></li>
                    <li><a href="@Url.Action("Services", "Home", new { category = "3c" })">3C 家電設計</a></li>
                    <li><a href="@Url.Action("Services", "Home", new { category = "reverse" })">逆向工程服務</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Company</h4>
                <ul class="footer-links">
                    <li><a href="@Url.Action("Info", "About")">關於智匯創新</a></li>
                    <li><a href="@Url.Action("Chairman", "About")">公司使命</a></li>
                    <li><a href="@Url.Action("Member", "About")">核心價值</a></li>
                    <li><a href="@Url.Action("Index", "Product")">作品集</a></li>
                    <li><a href="@Url.Action("Index", "Product")">得獎作品</a></li>
                    <li><a href="@Url.Action("Index", "News")">徵才消息</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Contact</h4>
                <ul class="footer-links">
                    <li><a href="@Url.Action("Index", "Contact")">聯絡我們</a></li>
                    <li><a href="@Url.Action("Index", "Quote")">快速報價</a></li>
                    <li><a href="@Url.Action("Index", "Quote")">線上 Q&A</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="footer-copy">© @DateTime.Now.Year 智匯創新股份有限公司 G-Wise Design Inc. All rights reserved.</p>
            <div class="footer-contact-info">
                <div>@ViewBag.Address</div>
                <div>TEL: @ViewBag.Phone · @ViewBag.Email</div>
            </div>
        </div>
    </footer>

    <!-- ========== 浮動按鈕 + LINE 弹窗 ========== -->
    <div class="float-btns">
        <!-- LINE 按钮：点击弹出模态框，不跳转 -->
        <a href="javascript:void(0);" onclick="openLineModal()" class="float-btn float-line" title="LINE 聯繫我們">
            <svg width="26" height="26" viewBox="0 0 48 48" fill="white">
                <path d="M24 4C12.95 4 4 11.82 4 21.4c0 5.8 3.27 10.96 8.37 14.32-.37 1.38-1.35 4.97-1.54 5.74-.24.98.36 .96 .75 .7.31-.21 4.96-3.27 6.97-4.6.79.11 1.6.17 2.45.17 11.05 0 20-7.82 20-17.4C44 11.82 35.05 4 24 4zm-6 22H14v-10h2v8h2v2zm4 0h-2V16h2v10zm10 0h-2l-4-6v6h-2V16h2l4 6v-6h2v10z" />
            </svg>
        </a>

        <!-- 回到顶部按钮 -->
        <div class="float-btn float-top" id="backTop" style="opacity:0;pointer-events:none;" onclick="window.scrollTo({top:0,behavior:'smooth'});" title="回到頂部">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                <path d="M18 15l-6-6-6 6" />
            </svg>
        </div>
    </div>

    <!-- 模态框 (Modal) - 显示 LINE 二维码（图片请自行替换） -->
    <div id="lineModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeLineModal()">&times;</span>
            <div class="modal-header">
                <h2>加入 LINE 好友</h2>
            </div>
            <div class="modal-body">
                <p>請使用 LINE 掃描下方 QR Code 加入好友</p>
                <!-- 二维码图片容器，请将您的图片路径替换到 src 中，或者直接放置 img 标签 -->
                <div id="qrcode-container">
                    <!-- 在这里放置您的二维码图片，例如： -->
                    <img src="~/images/web/qr-code.jpg" alt="LINE QR Code" />
                    <!-- 如果没有图片，可以留空注释，用户自行添加 -->
                </div>
            </div>
        </div>
    </div>

    <!-- ========== 全域 JavaScript ========== -->
    <script src="~/js/index.js"></script>
    <script>
        // 导航高亮
        $(function () {
            var currentUrl = window.location.pathname;
            var navMap = {
                'navHome': ['/Home', '/Home/Index'],
                'navAbout': ['/About', '/About/Index', '/About/Info', '/About/Chairman', '/About/Member', '/About/Constitution', '/About/Calendar', '/About/Contact'],
                'navService': ['/Service', '/Service/Index'],
                'navProduct': ['/Product', '/Product/Index'],
                'navNews': ['/News', '/News/Index'],
                'navContact': ['/Home/Contact', '/Contact']
            };
            for (var navId in navMap) {
                var urls = navMap[navId];
                for (var i = 0; i < urls.length; i++) {
                    if (currentUrl === urls[i] || currentUrl === urls[i] + '/' || currentUrl.startsWith(urls[i] + '/')) {
                        $('#' + navId).addClass('active');
                        break;
                    }
                }
            }
            if ($('.nav-links a.active').length === 0) {
                $('#navHome').addClass('active');
            }
        });

        // 菜单切换
        function toggleMenu() {
            $('#mobileMenu').toggleClass('open');
        }

        // 回到顶部
        var btn = document.getElementById('backTop');
        if (btn) {
            window.addEventListener('scroll', function () {
                var st = window.pageYOffset || document.documentElement.scrollTop;
                btn.style.opacity = st > 300 ? '1' : '0';
                btn.style.pointerEvents = st > 300 ? 'auto' : 'none';
            });
        }

        // Navbar 背景
        window.addEventListener('scroll', function () {
            var nav = document.getElementById('navbar');
            if (nav) {
                nav.style.background = window.pageYOffset > 50 ? 'rgba(17,17,17,0.98)' : 'rgba(17,17,17,0.95)';
            }
        });

        // ---------- LINE 弹窗 ----------
        var modal = document.getElementById('lineModal');
        var lineLink = document.getElementById('lineLink');
        var lineInviteUrl = 'https://lin.ee/xxxxxxx'; // 请替换为您的真实 LINE 邀请连结

        if (lineLink) {
            lineLink.href = lineInviteUrl;
            lineLink.innerText = lineInviteUrl;
        }

        window.openLineModal = function () {
            if (!modal) return;
            modal.style.display = 'block';
            document.body.style.overflow = 'hidden';
        };

        window.closeLineModal = function () {
            if (modal) {
                modal.style.display = 'none';
                document.body.style.overflow = '';
            }
        };

        window.onclick = function (event) {
            if (event.target === modal) {
                closeLineModal();
            }
        };
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>