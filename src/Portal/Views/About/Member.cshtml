@model Academy.Models.DictSet
@{
    ViewBag.Title = "核心價值｜智匯創新 G-wise Design";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="/css/about.css" rel="stylesheet" />
}

@section Scripts {
    <script src="/js/about.js"></script>
    <script>
        $(function () {
            $('.value-card, .mission-block').each(function () {
                $(this).css({ opacity: 0, transform: 'translateY(20px)' });
                var obs = new IntersectionObserver(function (entries) {
                    entries.forEach(function (e) {
                        if (e.isIntersecting) {
                            $(e.target).css({
                                transition: 'opacity 0.5s ease, transform 0.5s ease',
                                opacity: 1,
                                transform: 'translateY(0)'
                            });
                            obs.unobserve(e.target);
                        }
                    });
                }, { threshold: 0.15 });
                obs.observe(this);
            });
        });
        $(function () {
            var slides = $('.hero-slide');
            if (slides.length <= 1) return;
            var current = 0;
            var total = slides.length;
            var dotsContainer = $('#heroDots');
            // 產生指示點
            for (var i = 0; i < total; i++) {
                dotsContainer.append('<div class="hero-dot' + (i === 0 ? ' active' : '') + '" data-index="' + i + '"></div>');
            }
            function showSlide(index) {
                slides.removeClass('active');
                $(slides[index]).addClass('active');
                $('.hero-dot').removeClass('active');
                $('.hero-dot[data-index="' + index + '"]').addClass('active');
            }
            $('.hero-dot').on('click', function () {
                var idx = $(this).data('index');
                current = idx;
                showSlide(current);
            });
            // 自動輪播（每 5 秒）
            var interval = setInterval(function () {
                current = (current + 1) % total;
                showSlide(current);
            }, 5000);
            // 滑鼠移入暫停
            $('#heroSlider').on('mouseenter', function () { clearInterval(interval); });
            $('#heroSlider').on('mouseleave', function () {
                interval = setInterval(function () {
                    current = (current + 1) % total;
                    showSlide(current);
                }, 5000);
            });
            showSlide(0);
        });
    </script>
}

<!-- HERO -->
<div class="page-hero">
    <div class="page-hero-bg"><img src="@ViewBag.HeroImage" /></div>
    <div class="page-hero-gradient"></div>
    <div class="page-hero-content">
        <div class="page-hero-eyebrow">
            <div class="page-hero-line"></div>
            <span class="page-hero-label">About Us</span>
        </div>
        <h1 class="page-hero-title">公司簡介<br>About</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">首頁</a>
    <span>›</span>
    <span style="color:rgba(255,255,255,0.6)">公司簡介</span>
    <span>›</span>
    <span style="color:#fff">核心價值</span>
</div>

<!-- SUB NAV -->
<div class="sub-nav">
    <div class="sub-nav-inner">
        <a class="sub-tab" href="@Url.Action("Info", "About")">關於智匯創新</a>
        <a class="sub-tab" href="@Url.Action("Chairman", "About")">公司使命</a>
        <a class="sub-tab active" href="@Url.Action("Member", "About")">核心價值</a>
    </div>
</div>

<!-- MAIN -->
<div class="about-wrap">
    <div class="sidebar">
        <div class="sidebar-box">
            <h4>公司簡介</h4>
            <ul class="sub-menu-list">
                <li><a href="@Url.Action("Info", "About")">關於智匯創新 <span>›</span></a></li>
                <li><a href="@Url.Action("Chairman", "About")">公司使命 <span>›</span></a></li>
                <li><a class="active" href="@Url.Action("Member", "About")">核心價值 <span>›</span></a></li>
            </ul>
        </div>

        <div class="sidebar-box">
            <h4>設計服務</h4>
            <ul class="sub-menu-list">
                @if (ViewBag.CategoryList != null)
                {
                    var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
                    foreach (var cat in categories)
                    {
                        <li><a href="@Url.Action("Info", "Service", new { cataId = cat.Id })">@cat.Name <span>›</span></a></li>
                    }
                }
            </ul>
        </div>

        <div class="sidebar-box">
            <h4>聯絡資訊</h4>
            <div class="sidebar-info">
                <p><strong>智匯創新股份有限公司</strong></p>
                <p style="margin-top:8px;">@ViewBag.Address</p>
                <p style="margin-top:6px;"><strong>TEL：</strong>@ViewBag.Phone</p>
                <p style="margin-top:6px;"><strong>E-mail：</strong>@ViewBag.Email</p>
            </div>
        </div>
    </div>
    <div class="about-content">
        @if (Model != null)
        {
            @Html.Raw(Model.Value)
        }
        else
        {
            <div style="text-align:center;padding:100px;color:var(--gray);">暫無內容</div>
        }
    </div>


</div>