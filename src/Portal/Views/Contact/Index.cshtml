@{
    ViewBag.Title = "聯絡我們 Contact｜智匯創新 G-wise Design";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link href="/css/contact.css" rel="stylesheet" />
}

@section Scripts {
    <script src="/js/contact.js"></script>
}

<div class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80');"></div>
    <div class="page-hero-grad"></div>
    <div class="page-hero-content">
        <div class="eyebrow"><div class="eyebrow-line"></div><span class="eyebrow-label">Contact Us</span></div>
        <h1 class="page-title">聯絡我們<br>Contact</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="g-wise-homepage.html">首頁</a><span>›</span>
    <span style="color:#fff">聯絡我們</span>
</div>

<div class="contact-wrap">
    <div class="contact-left">
        <!-- 3 Info Cards -->
        <div class="info-cards">
            <div class="info-card">
                <div class="info-card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                </div>
                <h4>公司地址</h4>
                <p>@ViewBag.Address</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 12 19.79 19.79 0 011.62 3.38 2 2 0 013.6 1.21h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.91 8.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
                </div>
                <h4>電話 / 傳真</h4>
                <p>TEL：<a href="tel:033582500">@ViewBag.Phone</a><br>FAX：@ViewBag.Fax</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                </div>
                <h4>電子信箱</h4>
                <p>@ViewBag.Email</p>
            </div>
        </div>

        <!-- Map -->
        <div class="map-section">
            <div class="map-label">公司位置</div>
            <h3>地圖導覽</h3>
            <div class="map-frame">
                <iframe src="@ViewBag.MapUrl" style="border:0;width:100%;height:100%;min-height:420px;display:block;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="智匯創新股份有限公司位置"></iframe>
            </div>
        </div>

        <!-- Route -->
        <div class="route-box">
            <h4>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M12 3l9 9-9 9" /></svg>
                駕車前往
            </h4>
            @Html.Raw(ViewBag.TrafficGuide)
        </div>

    </div>

    <div class="contact-right">
        <div class="form-label">Get In Touch</div>
        <h2 class="form-section-title">留下訊息<br>聯繫我們</h2>

        <!-- 添加 data-submit-url 属性 -->
        <form id="contactForm" method="post" data-submit-url="@Url.Action("PostMsg", "Contact")">
            <div class="form-row">
                <div class="form-group">
                    <label>姓名 <span>*</span></label>
                    <input class="form-input" name="UserName" type="text" placeholder="您的姓名" required>
                </div>
                <div class="form-group">
                    <label>公司名稱</label>
                    <input class="form-input" name="CompanyName" type="text" placeholder="公司或品牌名稱">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>電話 <span>*</span></label>
                    <input class="form-input" name="Tel" type="tel" placeholder="聯絡電話" required>
                </div>
                <div class="form-group">
                    <label>電子信箱 <span>*</span></label>
                    <input class="form-input" name="Mail" type="email" placeholder="your@email.com" required>
                </div>
            </div>

            <div class="form-group">
                <label>服務項目</label>
                <select class="form-select form-input" name="CategoryName">
                    <option value="" disabled selected>請選擇您感興趣的服務</option>
                    @if (ViewBag.CategoryList != null)
                    {
                        var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
                        foreach (var cat in categories)
                        {
                            <option value="@cat.Name">@cat.Name</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>訊息內容 <span>*</span></label>
                <textarea class="form-textarea" name="Content" placeholder="請描述您的設計需求或問題..." required></textarea>
            </div>

            <button type="submit" class="form-submit">送出訊息</button>
            <p class="form-note">* 為必填欄位。我們將在 1–2 個工作日內與您聯繫。<br>您也可以直接來信：@ViewBag.Email</p>
        </form>

        <div class="form-success" id="formSuccess" style="display:none;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6DB82A" stroke-width="2" style="margin-bottom:10px;"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            <p>訊息已成功送出！我們將盡快與您聯繫，感謝您的來訊。</p>
        </div>
    </div>
</div>