@{
    ViewBag.Title = "新聞活動 News｜智匯創新 G-wise Design";
}

@section Styles {
    <link href="/css/news.css" rel="stylesheet" />
}

@section Scripts {
    <script src="/js/news.js"></script>
}

<!-- HERO -->
<div class="page-hero">
    <div class="page-hero-bg" style="background-image:url('https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=1600&q=80');"></div>
    <div class="page-hero-grad"></div>
    <div class="page-hero-content">
        <div class="eyebrow">
            <div class="eyebrow-line"></div>
            <span class="eyebrow-label">News &amp; Events</span>
        </div>
        <h1 class="page-title">新聞活動<br>News</h1>
    </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="@Url.Action("Index", "Home")">首頁</a>
    <span>›</span>
    <span style="color:#fff" id="bcText">新聞消息</span>
</div>

<!-- TAB NAV - 从后端数据绑定 -->
<div class="tab-nav">
    <button class="tab-btn active" data-cat-id="0" onclick="loadNewsList(0, '新聞消息')">全部新聞</button>
    @if (ViewBag.CategoryList != null)
    {
        var categories = ViewBag.CategoryList as List<Academy.Models.Category> ?? new List<Academy.Models.Category>();
        foreach (var cat in categories)
        {
            <button class="tab-btn" data-cat-id="@cat.Id" onclick="loadNewsList(@cat.Id, '@cat.Name')">@cat.Name</button>
        }
    }
</div>

<!-- NEWS LIST TAB -->
<div id="panelNews">
    <div style="text-align:center;padding:100px;">
        <div class="loading-spinner"></div>
        <p>載入中...</p>
    </div>
</div>

<!-- HIRING TAB -->
<div id="panelHiring" style="display:none;">
    <div class="hiring-wrap">
        <div class="hiring-section">
            <h3>企業精神</h3>
            <p>針對不同市場需求，為客戶創造最高品牌價值產品，是智匯創新的企業精神指標。智匯創新本著為客戶創造最高價值的心態做設計，而這些核心的能力，須從人才出發，結合眾人智慧，進而設計出具備外觀優美、品質優良的產品。</p>
        </div>

        <div class="hiring-section">
            <h3>企業文化</h3>
            <p>智匯創新特別著重在人才的專業素質與人格的培育，開放式管理風格，注重自我管理與創新精神。</p>
        </div>

        <div class="hiring-section">
            <h3>挑戰與機會</h3>
            <p>智匯創新不斷從事計畫性產品設計，從產品概念、產品外觀設計、機構設計、產品模型都是本公司的專業領域範圍，我們誠摯歡迎可塑性高且自我期許未來成為全方位人才的你加入我們行列。</p>
        </div>

        <div class="hiring-info-grid">
            <div class="hiring-info-card">
                <h4>工作時間</h4>
                <p>周休二日<br>08：30 — 17：30<br>午休時間一小時</p>
            </div>
            <div class="hiring-info-card">
                <h4>福利制度</h4>
                <p>年終固定提撥 8% 分紅<br>三節禮品<br>完善勞健保</p>
            </div>
            <div class="hiring-info-card">
                <h4>應徵方式</h4>
                <p>請下載履歷表格，填妥後 e-mail 至：<br><a href="mailto:service@g-wise.com">service@g-wise.com</a></p>
            </div>
            <div class="hiring-info-card">
                <h4>公司地址</h4>
                <p>桃園市桃園區經國路9號3樓之2<br>TEL：(03)358-2500</p>
            </div>
        </div>

        <a href="mailto:service@g-wise.com" class="hiring-cta">
            立即投遞履歷
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </a>
    </div>
</div>

<!-- NEWS DETAIL MODAL -->
<div class="detail-modal" id="detailModal">
    <div class="detail-inner">
        <button class="detail-back" onclick="closeDetail()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7" /></svg>
            返回新聞列表
        </button>
        <div class="detail-tag" id="dTag">新聞消息 · News</div>
        <div class="detail-date" id="dDate"></div>
        <img class="detail-img" id="dImg" src="" alt="">
        <div class="detail-body" id="dBody"></div>
    </div>
</div>

<!-- CTA BAR -->
<div class="cta-bar">
    <div class="cta-title">有設計需求？<br>歡迎與我們聯繫合作</div>
    <a href="@Url.Action("Quote", "Home")" class="btn-white">立即詢價 →</a>
</div>